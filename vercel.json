{
  "version": 2,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npx prisma generate && npx prisma db push && npx ts-node -r tsconfig-paths/register src/seed/seed.ts",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
