generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BATCH_OPERATOR
  SUPERVISOR
  QA_REVIEWER
  QA_MANAGER
  QUALIFIED_PERSON
}

enum BatchState {
  DRAFT
  INITIATED
  LINE_CLEARANCE
  IN_PROGRESS
  DEVIATION
  HOLD
  PENDING_QA
  PENDING_QP
  RELEASED
  REJECTED
}

enum DeviationStatus {
  OPEN
  UNDER_REVIEW
  CLOSED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime @default(now())

  batches          Batch[]             @relation("InitiatedBy")
  auditLogs        AuditLog[]
  deviations       Deviation[]         @relation("RaisedBy")
  issuances        MaterialIssuance[]  @relation("IssuancesIssued")
  issuesRaised     Issue[]             @relation("IssueRaisedBy")
  issuesAssigned   Issue[]             @relation("IssueAssignedTo")
  issuesResolved   Issue[]             @relation("IssueResolvedBy")
}

model BatchTemplate {
  id          String   @id @default(uuid())
  productCode String   @unique
  productName String
  steps       Json
  createdAt   DateTime @default(now())

  batches  Batch[]
  bomItems BomItem[]
}

model Batch {
  id          String     @id @default(uuid())
  batchNumber String     @unique
  productCode String
  productName String
  batchSize   Float
  state       BatchState @default(DRAFT)
  initiatedBy String
  initiatedAt DateTime?
  completedAt DateTime?
  steps       Json
  signatures  Json       @default("[]")
  templateId  String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  template   BatchTemplate      @relation(fields: [templateId], references: [id])
  initiator  User               @relation("InitiatedBy", fields: [initiatedBy], references: [id])
  deviations Deviation[]
  auditLogs  AuditLog[]
  issuances  MaterialIssuance[]
  issues     Issue[]
}

model Deviation {
  id              String          @id @default(uuid())
  batchId         String
  stepNumber      Int
  fieldName       String
  expectedRange   String
  actualValue     Float
  raisedBy        String
  raisedAt        DateTime        @default(now())
  status          DeviationStatus @default(OPEN)
  resolutionNotes String?
  closedBy        String?
  closedAt        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  batch  Batch @relation(fields: [batchId], references: [id])
  raiser User  @relation("RaisedBy", fields: [raisedBy], references: [id])
}

// Append-only audit log — never UPDATE or DELETE rows in this table
model AuditLog {
  id          String   @id @default(uuid())
  eventType   String
  entityType  String
  entityId    String   // primary entity ID (could be batchId, userId, etc.)
  batchId     String?  // FK to Batch — set when the event is Batch-related
  actorId     String
  actorRole   String
  timestamp   DateTime @default(now())
  beforeState Json?
  afterState  Json?
  metadata    Json?

  actor User   @relation(fields: [actorId], references: [id])
  batch Batch? @relation(fields: [batchId], references: [id])

  @@index([entityId])
  @@index([batchId])
  @@index([actorId])
  @@index([timestamp])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Bill of Materials ────────────────────────────────────────────────────────

model Material {
  id           String   @id @default(uuid())
  materialCode String   @unique
  materialName String
  unit         String   // g, kg, mL, L, units
  description  String?
  createdAt    DateTime @default(now())

  bomItems  BomItem[]
  issuances MaterialIssuance[]
}

model BomItem {
  id         String  @id @default(uuid())
  templateId String
  materialId String
  qtyPerKg   Float   // required quantity (in material.unit) per 1 kg of batch output
  notes      String?

  template  BatchTemplate      @relation(fields: [templateId], references: [id])
  material  Material           @relation(fields: [materialId], references: [id])
  issuances MaterialIssuance[]

  @@unique([templateId, materialId])
}

model MaterialIssuance {
  id          String   @id @default(uuid())
  batchId     String
  bomItemId   String
  materialId  String
  lotNumber   String
  requiredQty Float    // calculated at issuance time
  issuedQty   Float
  issuedBy    String
  issuedAt    DateTime @default(now())

  batch    Batch    @relation(fields: [batchId], references: [id])
  bomItem  BomItem  @relation(fields: [bomItemId], references: [id])
  material Material @relation(fields: [materialId], references: [id])
  issuer   User     @relation("IssuancesIssued", fields: [issuedBy], references: [id])
}

// ─── Issues ───────────────────────────────────────────────────────────────────

model Issue {
  id          String        @id @default(uuid())
  batchId     String?
  title       String
  description String
  severity    IssueSeverity @default(MEDIUM)
  status      IssueStatus   @default(OPEN)
  raisedBy    String
  raisedAt    DateTime      @default(now())
  assignedTo  String?
  resolution  String?
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  batch    Batch? @relation(fields: [batchId], references: [id])
  raiser   User   @relation("IssueRaisedBy", fields: [raisedBy], references: [id])
  assignee User?  @relation("IssueAssignedTo", fields: [assignedTo], references: [id])
  resolver User?  @relation("IssueResolvedBy", fields: [resolvedBy], references: [id])
}
